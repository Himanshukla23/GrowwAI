# ──────────────────────────────────────────────────────────────────────────────
# GrowwAI — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file as `.env` and fill in your actual keys.
# NEVER commit the real .env file — it is already in .gitignore.

# ── LLM (Groq) — used by Grounded Answer Generation Layer (§4.5) ─────────────
# This is the current default as per README.md and generator.py
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── LLM (Gemini) — Alternate ──────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# ── API Authentication ────────────────────────────────────────────────────────
API_AUTH_TOKEN=your_api_auth_token_here

# ── ChromaDB Cloud — Indexing Layer (§4.3) ────────────────────────────────────
# Sign up at https://trychroma.com and create a database to get these values.
# If CHROMA_API_KEY is set, the indexer uses ChromaDB Cloud.
# If CHROMA_API_KEY is empty, the indexer falls back to local persistent storage.
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=your_database_name_here

# ── ChromaDB Local Fallback ──────────────────────────────────────────────────
CHROMA_DB_DIR=data/chroma
CHROMA_COLLECTION=groww_mf_chunks

# ── Embedding Model — Indexing & Retrieval (§4.3 / §4.4) ─────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
